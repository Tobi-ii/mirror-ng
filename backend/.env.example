# ==============================================================================
# Mirror.ng Backend Environment Configuration Template
# Copy this file to .env and fill in your actual credentials.
# ==============================================================================

# --- EMAIL PROVIDER OPTIONS ---
# Options: 'yahoo', 'gmail' (with App Password), or 'gmail_oauth' (via Google API)
EMAIL_PROVIDER=yahoo
YAHOO_EMAIL=your_email@yahoo.com
YAHOO_APP_PASSWORD=your_yahoo_app_password

# --- GOOGLE OAUTH CONFIGURATION (Required for "Login with Gmail" OAuth button) ---
# Set up a Web Application OAuth Client ID on Google Cloud Console:
# Redirect URI should be: http://localhost:8000/api/auth/google/callback
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REDIRECT_URI=http://localhost:8000/api/auth/google/callback

# --- LLM API KEYS (For ML Transaction Insights / AI Assistant Chat) ---
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# --- DATABASE CONFIGURATION ---
DATABASE_URL=sqlite:///./mirror.db

# --- SECURITY & JWT ---
# Use a random 32-character or longer string for SECRET_KEY in production
SECRET_KEY=change_this_to_a_secure_random_string_minimum_32_chars
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# --- APP SETTINGS ---
DEBUG=True
# CORS configuration (comma-separated origins allowed to talk to backend)
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
# Frontend callback URL for OAuth flow
FRONTEND_URL=http://localhost:3000
