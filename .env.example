# Mirror.ng Environment Configuration
# Copy this to .env and fill in your values:
#   cp .env.example .env && nano .env

# LLM API Keys (required for Agent Chat & Insights)
OPENROUTER_API_KEY=your_openrouter_api_key

# Google OAuth (optional — only needed for Gmail OAuth login)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=

# Database
DATABASE_URL=sqlite:///./data/mirror.db

# Security
# CHANGE THIS in production! Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=change-me-in-production
# Email password encryption key (separate from SECRET_KEY)
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
EMAIL_ENCRYPTION_KEY=change-me-in-production

# App
CORS_ORIGINS=http://localhost:80,http://localhost:3000,http://localhost:5173
FRONTEND_URL=http://localhost:80
DEBUG=false
